# Image generation
IMAGE_PROVIDER=placeholder
IMAGE_API_KEY=
IMAGE_API_BASE=
# Output: native (recommended) or e.g. 2048x2048, 1600x1600
IMAGE_OUTPUT_SIZE=native
IMAGE_MAX_RETRIES=3

GEMINI_MODEL_ID=gemini-2.5-flash-image
OPENAI_MODEL_ID=gpt-image-1

# ByteDance Volcano Ark / Doubao Seedream. Use IMAGE_PROVIDER=doubao.
# Fill IMAGE_API_KEY with your Volcano Ark or compatible relay API key.
DOUBAO_MODEL_ID=doubao-seedream-5-0-260128
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_TIMEOUT=300

# Xais relay (xais.dchai.cn). Use IMAGE_PROVIDER=xais + IMAGE_API_KEY=<xtoken>.
# Models: Nano_Banana_Pro_2K_5 (cheapest) / Nano_Banana_Pro_2K_0 / Nano_Banana_Pro_4K_0 /
#         Nano_Banana_2_2K_0 / Nano_Banana_2_4K_0
XAIS_MODEL_ID=Nano_Banana_Pro_2K_0
XAIS_API_BASE=https://sg2.dchai.cn
XAIS_TIMEOUT=300

# Shiyun relay (shiyunapi.com). Use IMAGE_PROVIDER=shiyun + IMAGE_API_KEY=<token>.
# Create token: https://shiyunapi.com/console/token  ·  Models: https://shiyunapi.com/pricing
# Recommended: gemini-2.5-flash-image (Nano Banana standard) for image-to-image.
# gpt-image-2 uses a different endpoint and may not support reference images.
SHIYUN_MODEL_ID=gemini-2.5-flash-image
SHIYUN_API_BASE=https://shiyunapi.com
SHIYUN_TIMEOUT=300

# Brief LLM (optional; placeholder = copy global briefs.yaml)
BRIEF_LLM_PROVIDER=placeholder
BRIEF_LLM_API_KEY=
BRIEF_LLM_API_BASE=
